# ── Sirin 配置範本 ────────────────────────────────────────────────────────────
# 複製此檔案為 .env，填入你的設定後重啟 Sirin。
# Copy to .env, fill in your settings, then restart Sirin.
#
# ⚠️  首次安裝必讀 / First-time setup
#    1. 選一個 LLM provider 並取消對應區塊的注解
#    2. 如需測試 Flutter/Canvas UI，必須選支援 vision 的 provider
#       (Gemini 或 Anthropic — Ollama 預設模型不支援 vision)
#    3. 填入 API key 後儲存，重啟 Sirin

# ── LLM 後端（三擇一）────────────────────────────────────────────────────────

# 選項 A：Google Gemini（推薦）— 支援 vision，可測 Flutter canvas UI
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here          # 從 https://aistudio.google.com 取得
# GEMINI_MODEL=gemini-2.0-flash         # 或 gemini-1.5-pro
# GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai

# 選項 B：Anthropic Claude — 支援 vision
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...          # 從 https://console.anthropic.com 取得
# ANTHROPIC_MODEL=claude-sonnet-4-6
# ANTHROPIC_BASE_URL=https://api.anthropic.com/v1

# 選項 C：Ollama（本地免費）— ⚠️ 預設模型不支援 vision
# 若需 vision：改用 llava、llama3.2-vision 等支援 vision 的模型
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2                 # ← 不支援 vision，無法測 Flutter canvas

# 選項 D：LM Studio（本地，OpenAI 相容）
# LLM_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=llama3.2
# LM_STUDIO_API_KEY=                    # 多數 LM Studio 安裝不需要

# 選項 E：OpenAI 或 OpenAI 相容（DeepSeek / OpenRouter / 任意自架）
# LLM_PROVIDER=openai
# OPENAI_API_KEY=sk-...
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_MODEL=gpt-4o-mini

# 通用 model override（任何 provider 都吃）— 主 model 名稱。
# LLM_MODEL=

# 預設（未設定時 Sirin 會啟動但 AI 功能停用，Settings 頁顯示警告）
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM Fallback chain（強烈建議）────────────────────────────────────────────
# 主 LLM 遇到 429 rate limit 時自動切換，立刻生效（不再等 30s+60s+120s retry）。
# 推薦填入 DeepSeek 官方 API：
#   1. 到 https://platform.deepseek.com 申請（新帳號有 $5 免費額度）
#   2. 取得 API key 填入下方
#   3. deepseek-chat = 最新 DeepSeek V4，速度快、推理強
#
# LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
# LLM_FALLBACK_API_KEY=sk-...
# LLM_FALLBACK_MODEL=deepseek-chat
#
# 若使用 OpenRouter（需充值），也可填：
# LLM_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
# LLM_FALLBACK_API_KEY=sk-or-...
# LLM_FALLBACK_MODEL=deepseek/deepseek-v4-pro

# ── Multi-model routing（選填）────────────────────────────────────────────────
# 未設定時全部使用主 model。

# ROUTER_MODEL=tinyllama      # Planner + Router 用小型快速模型
# CODING_MODEL=qwen2.5-coder  # Coding Agent 專用
# LARGE_MODEL=llama3:70b      # 高推理需求任務

# ROUTER_LLM_PROVIDER：Router 用獨立 provider（不同於主 LLM）。
# ROUTER_LLM_PROVIDER=ollama

# ── Telegram API（選填）──────────────────────────────────────────────────────
# 從 https://my.telegram.org → "API development tools" 取得

# TG_API_ID=
# TG_API_HASH=
# TG_PHONE=+886...            # 國際格式

TG_AUTO_REPLY=false
# TG_AUTO_REPLY_TEXT=自動回覆訊息內容    # auto-reply 開啟時的訊息文字
TG_REPLY_PRIVATE=true
TG_REPLY_GROUPS=false
# TG_GROUP_IDS=               # 逗號分隔群組 ID（空白 = 所有群組）
# TG_REQUIRE_LOGIN=false      # 啟動前要求 Telegram session 已登入（CI 用）

# TG_STARTUP_MSG=Sirin started at {time}
# TG_STARTUP_TARGET=saved_messages

TG_DEBUG_UPDATES=false

# ── Web search（選填）─────────────────────────────────────────────────────────
# 未設定時 fallback 到 DuckDuckGo。
# SEARXNG_BASE_URL=http://localhost:8080

# ── Knowledge Base / Claude in Chrome（選填）────────────────────────────────
# kb_search / kb_get MCP tools 預設關閉；要讓 Claude in Chrome (Beta) 從
# AgoraMarket KB 查資料時，請啟用以下設定。Bearer token 留在 Sirin .env，
# Chrome extension 永遠看不到。
# KB_ENABLED=1
# KB_MCP_URL=https://agoramarketapi.purrtechllc.com/api/mcp
# KB_MCP_BEARER=your_kb_bearer_token_here
# KB_PROJECT=agora_market

# Claude in Chrome (Beta) extension ID — 設定後 Sirin MCP server 只接受
# 來自該 extension 的請求（chrome-extension://[id]）。未設定 = 允許所有
# origin（向後相容 Claude Desktop / Claude Code / curl）。
# 在 chrome://extensions/ 找到 Claude 的 ID 填入。
# CLAUDE_CHROME_EXT_ID=bfnaelmomeimhlpmgjnjophhpkkoljpa

# ── 瀏覽器（選填）────────────────────────────────────────────────────────────

# Chrome headless 預設值，每測試的 YAML browser_headless: 仍可覆寫。
# Flutter CanvasKit / WebGL 內容 headless 模式不會 paint — 設 false 才能拿到
# 實際畫面。22 個 Agora YAML 已移除個別設定，改靠這個全域旗標（commit cb49ea5）。
# SIRIN_BROWSER_HEADLESS=false

# 持久化 Chrome profile（cookies / localStorage / IndexedDB 留下）。
#   1 = 用 <app_data_dir>/chrome-profile（適合大多人）
#   絕對路徑 = 自訂位置
#   未設 = 每次 launch 用全新 profile（預設）
# SIRIN_PERSISTENT_PROFILE=1

# 全域預設 viewport（測試沒設 viewport 時用）。Format: WIDTHxHEIGHT。
# SIRIN_DEFAULT_VIEWPORT=1440x1600

# 截圖前注入 CSS 隱私遮罩（password / OTP 欄位 blur+變色）。預設 1（開啟）。
# SIRIN_PRIVACY_MASK=1

# Per-test glob blocklist 擴充（authz `deny[].url_pattern` 之外）。
# SIRIN_BLOCKED_URL_PATTERNS=*/payment/confirm,*/billing

# Shell-out actions 允許白名單（claude_session 等）。
# SIRIN_ALLOWED_COMMANDS=

# Gemini concurrency 上限（process-wide）— 預設 3，free tier ~15 RPM 配 3 最穩。
# 太高（>5）會觸發 429 風暴或空回應 bug。
# GEMINI_CONCURRENCY=3

# Gemini 每分鐘上限（token bucket rate limiter）— 預設 8（10 RPM free tier 留 20% 緩衝）。
# 設 0 關掉。
# GEMINI_RPM=8

# ── RPC / MCP server（選填）─────────────────────────────────────────────────

# MCP / web UI / RPC server 監聽 port。預設 7700；自動 fallback 到 7701-7703。
# SIRIN_RPC_PORT=7700

# Headless 模式：跳過 auto-open 預設瀏覽器到 :7700/ui/。等同 CLI flag --headless。
# 適合 server / CI / SSH 環境。
# SIRIN_HEADLESS=1

# 覆蓋專案根目錄（用於 codebase 自我檢視；預設 = Cargo.toml 編譯時的目錄）。
# SIRIN_PROJECT_ROOT=

# claude / gh CLI 不在 PATH 時填路徑。
# SIRIN_CLAUDE_BIN=
# SIRIN_GH_BIN=

# ── Vision LLM（選填，獨立 provider 用於截圖分析）──────────────────────────

# 未設定 → 用主 LLM。設定後 screenshot_analyze / vision 走獨立 endpoint。
# LLM_VISION_BACKEND=
# LLM_VISION_BASE_URL=
# LLM_VISION_API_KEY=
# LLM_VISION_MODEL=

# ── test_runner LLM 覆蓋（選填）─────────────────────────────────────────────

# 設成 "claude_cli" 或 "claude" 改用 `claude -p` subprocess（Max plan，免 API key，
# JSON 輸出可靠度高很多，每呼叫多 ~3-5s）。YAML 的 `llm_backend:` 仍可覆寫。
# TEST_RUNNER_LLM_BACKEND=

# ── Failure 通知（選填）─────────────────────────────────────────────────────

# 兩個都設定後，test_runner 失敗時自動 ping Telegram bot。
# SIRIN_NOTIFY_BOT_TOKEN=
# SIRIN_NOTIFY_CHAT_ID=

# 失敗通知去重視窗（秒）— 同一 test_id 在此區間內只通知一次。
# NOTIFY_DEDUP_WINDOW_SECS=

# ── Multi-agent squad / 自動 loop（選填）────────────────────────────────────

# AUTONOMOUS_MAX_CONCURRENT=
# AUTONOMOUS_MAX_PER_CYCLE=
# AUTONOMOUS_COOLDOWN_SECS=
# AUTONOMOUS_MAX_RETRIES=
# FOLLOWUP_INTERVAL_SECS=
# TASK_LOG_MAX_LINES=

# 並行批次測試啟動間錯（ms）— 預設 0，可設 ~500 緩衝 Chrome 啟動負載。
# BATCH_START_STAGGER_MS=

# ── KB 寫入 telemetry（選填）────────────────────────────────────────────────

# 讓 test_runner 自動寫 KB entries 紀錄發現。預設 0（關閉）。
# 開啟後每次失敗 / 修復循環會寫一條 KB topic — 量大，謹慎使用。
# KB_WRITE_TELEMETRY=0

# ── Auto-fix verify 預設值（選填）───────────────────────────────────────────

# scripts/verify-new-actions.sh + auto-fix flow 的預設 repo / issue。
# SIRIN_VERIFY_REPO=Redandan/AgoraMarket
# SIRIN_VERIFY_ISSUE=
