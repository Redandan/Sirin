# ── LLM backend ────────────────────────────────────────────────────────────────
# Choose one provider.  The Settings UI can override these after first launch.

LLM_PROVIDER=ollama          # ollama | lmstudio | gemini | anthropic

# Ollama (default, free, runs locally)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# LM Studio (OpenAI-compatible local server)
# LLM_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=llama3.2

# Google Gemini (cloud)
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# Anthropic Claude (cloud — used for the "Claude" meeting participant)
# ANTHROPIC_API_KEY=sk-ant-...
# ANTHROPIC_MODEL=claude-sonnet-4-6

# ── Multi-model routing (optional) ─────────────────────────────────────────────
# Falls back to the main model when not set.

# ROUTER_MODEL=tinyllama      # Small/fast model for Planner + Router
# CODING_MODEL=qwen2.5-coder  # Dedicated model for Coding Agent
# LARGE_MODEL=llama3:70b      # High-reasoning tasks

# ── Telegram API ──────────────────────────────────────────────────────────────
# Obtain credentials from https://my.telegram.org → "API development tools"

# TG_API_ID=
# TG_API_HASH=
# TG_PHONE=+886...            # International format

# Reply settings
TG_AUTO_REPLY=false
TG_REPLY_PRIVATE=true
TG_REPLY_GROUPS=false
# TG_GROUP_IDS=               # Comma-separated group IDs (blank = all groups)

# TG_STARTUP_MSG=Sirin started at {time}
# TG_STARTUP_TARGET=saved_messages

TG_DEBUG_UPDATES=false

# ── Web search (optional) ──────────────────────────────────────────────────────
# Falls back to DuckDuckGo when not set.
# SEARXNG_BASE_URL=http://localhost:8080
