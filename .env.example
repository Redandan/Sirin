# ── Telegram API ──────────────────────────────────────────────────────────────
# Obtain your API credentials from https://my.telegram.org → "API development tools"

TG_API_ID=12345678
TG_API_HASH=your_api_hash_here

# Phone number for non-interactive sign-in (optional; includes country code)
# TG_PHONE=+886912345678

# Set to 1 to require Telegram login at startup; 0 = optional (default)
# TG_REQUIRE_LOGIN=0

# ── Reply settings ─────────────────────────────────────────────────────────────

# Enable AI auto-reply for incoming messages
TG_AUTO_REPLY=false

# Reply to private (1-on-1) chats
TG_REPLY_PRIVATE=true

# Reply inside group/channel chats
TG_REPLY_GROUPS=false

# Comma-separated group/channel IDs to monitor (leave blank = all groups)
# TG_GROUP_IDS=

# ── LLM backend ────────────────────────────────────────────────────────────────
# Ollama (default if no LM Studio vars are set)
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2

# LM Studio
# LM_STUDIO_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=

# Dedicated model for the Coding Agent (falls back to CODING_MODEL if unset)
# CODING_MODEL=

# ── Startup message ────────────────────────────────────────────────────────────
# Send a message when the Telegram listener connects (uses {time} placeholder)
# TG_STARTUP_MSG=Sirin started at {time}
# TG_STARTUP_TARGET=saved_messages   # target username or "saved_messages"

# ── Debug ──────────────────────────────────────────────────────────────────────
# Print every incoming Telegram update to the log panel
TG_DEBUG_UPDATES=false
