# ── Sirin 配置範本 ────────────────────────────────────────────────────────────
# 複製此檔案為 .env，填入你的設定後重啟 Sirin。
# Copy to .env, fill in your settings, then restart Sirin.
#
# ⚠️  首次安裝必讀 / First-time setup
#    1. 選一個 LLM provider 並取消對應區塊的注解
#    2. 如需測試 Flutter/Canvas UI，必須選支援 vision 的 provider
#       (Gemini 或 Anthropic — Ollama 預設模型不支援 vision)
#    3. 填入 API key 後儲存，重啟 Sirin

# ── LLM 後端（三擇一）────────────────────────────────────────────────────────

# 選項 A：Google Gemini（推薦）— 支援 vision，可測 Flutter canvas UI
# LLM_PROVIDER=gemini
# GEMINI_API_KEY=your_key_here          # 從 https://aistudio.google.com 取得
# GEMINI_MODEL=gemini-2.0-flash         # 或 gemini-1.5-pro

# 選項 B：Anthropic Claude — 支援 vision
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...          # 從 https://console.anthropic.com 取得
# ANTHROPIC_MODEL=claude-sonnet-4-6

# 選項 C：Ollama（本地免費）— ⚠️ 預設模型不支援 vision
# 若需 vision：改用 llava、llama3.2-vision 等支援 vision 的模型
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434
# OLLAMA_MODEL=llama3.2                 # ← 不支援 vision，無法測 Flutter canvas

# 選項 D：LM Studio（本地，OpenAI 相容）
# LLM_PROVIDER=lmstudio
# LM_STUDIO_BASE_URL=http://localhost:1234/v1
# LM_STUDIO_MODEL=llama3.2

# 預設（未設定時 Sirin 會啟動但 AI 功能停用，Settings 頁顯示警告）
LLM_PROVIDER=ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# ── LLM Fallback chain（強烈建議）────────────────────────────────────────────
# 主 LLM 遇到 429 rate limit 時自動切換，立刻生效（不再等 30s+60s+120s retry）。
# 推薦填入 DeepSeek 官方 API：
#   1. 到 https://platform.deepseek.com 申請（新帳號有 $5 免費額度）
#   2. 取得 API key 填入下方
#   3. deepseek-chat = 最新 DeepSeek V4，速度快、推理強
#
# LLM_FALLBACK_BASE_URL=https://api.deepseek.com/v1
# LLM_FALLBACK_API_KEY=sk-...
# LLM_FALLBACK_MODEL=deepseek-chat
#
# 若使用 OpenRouter（需充值），也可填：
# LLM_FALLBACK_BASE_URL=https://openrouter.ai/api/v1
# LLM_FALLBACK_API_KEY=sk-or-...
# LLM_FALLBACK_MODEL=deepseek/deepseek-v4-pro

# ── Multi-model routing（選填）────────────────────────────────────────────────
# 未設定時全部使用主 model。

# ROUTER_MODEL=tinyllama      # Planner + Router 用小型快速模型
# CODING_MODEL=qwen2.5-coder  # Coding Agent 專用
# LARGE_MODEL=llama3:70b      # 高推理需求任務

# ── Telegram API（選填）──────────────────────────────────────────────────────
# 從 https://my.telegram.org → "API development tools" 取得

# TG_API_ID=
# TG_API_HASH=
# TG_PHONE=+886...            # 國際格式

TG_AUTO_REPLY=false
TG_REPLY_PRIVATE=true
TG_REPLY_GROUPS=false
# TG_GROUP_IDS=               # 逗號分隔群組 ID（空白 = 所有群組）

# TG_STARTUP_MSG=Sirin started at {time}
# TG_STARTUP_TARGET=saved_messages

TG_DEBUG_UPDATES=false

# ── Web search（選填）─────────────────────────────────────────────────────────
# 未設定時 fallback 到 DuckDuckGo。
# SEARXNG_BASE_URL=http://localhost:8080

# ── Knowledge Base / Claude in Chrome（選填）────────────────────────────────
# kb_search / kb_get MCP tools 預設關閉；要讓 Claude in Chrome (Beta) 從
# AgoraMarket KB 查資料時，請啟用以下設定。Bearer token 留在 Sirin .env，
# Chrome extension 永遠看不到。
# KB_ENABLED=1
# KB_MCP_URL=https://agoramarketapi.purrtechllc.com/api/mcp
# KB_MCP_BEARER=your_kb_bearer_token_here
# KB_PROJECT=agora_market

# Claude in Chrome (Beta) extension ID — 設定後 Sirin MCP server 只接受
# 來自該 extension 的請求（chrome-extension://[id]）。未設定 = 允許所有
# origin（向後相容 Claude Desktop / Claude Code / curl）。
# 在 chrome://extensions/ 找到 Claude 的 ID 填入。
# CLAUDE_CHROME_EXT_ID=bfnaelmomeimhlpmgjnjophhpkkoljpa
