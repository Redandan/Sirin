# ── Security: never track secrets or sensitive runtime data ──────────────────
.env
.env.*
*.session
/data/auth/
/data/tracking/task.jsonl

# ── Build artifacts ───────────────────────────────────────────────────────────
/target/
dist/
out/
build/

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Tauri ─────────────────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/WixTools/

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Explicitly track config YAML files (override any broad ignore rules) ──────
!/config/
!/config/*.yaml
