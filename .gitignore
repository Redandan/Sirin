# ── Security: never track secrets or sensitive runtime data ──────────────────
.env
.env.*
!.env.example
*.session
/data/auth/
/data/tracking/task.jsonl
/data/test_failures/
/data/test_*.png
/data/teams_profile/
sirin.log

# ── Build artifacts ───────────────────────────────────────────────────────────
/target/
.claude/worktrees/*/target/
dist/
out/
build/
/Output/

# ── Runtime / verification dirs ───────────────────────────────────────────────
.sirin-verify/
.claude/scheduled_tasks.lock

# ── Node / Next.js ────────────────────────────────────────────────────────────
node_modules/
.next/
.turbo/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── Tauri auto-generated schemas ──────────────────────────────────────────────
/gen/

# ── Tauri ─────────────────────────────────────────────────────────────────────
src-tauri/target/
src-tauri/WixTools/

# ── OS artifacts ─────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor / IDE ──────────────────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Explicitly track config YAML files (override any broad ignore rules) ──────
!/config/
!/config/*.yaml
.claude/settings.local.json
sirin_*.log

# ── Test launch captures (sirin-7700.err / sirin-boot.out / etc.) ─────────────
sirin-*.err
sirin-*.out
