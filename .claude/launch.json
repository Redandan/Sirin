{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "sirin-web",
      "runtimeExecutable": "dx",
      "runtimeArgs": ["serve", "--platform", "fullstack"],
      "port": 8080
    },
    {
      "name": "sirin-dev",
      "runtimeExecutable": "cargo",
